{
  "manifest_version": 3,
  "name": "Card Reader",
  "description": "Detect merchant context and recommend the best card from Card Reader.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://card-reader-xi.vercel.app/*", "http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.patagonia.com/*",
        "https://*.amazon.com/*",
        "https://*.delta.com/*",
        "https://*.united.com/*",
        "https://*.aa.com/*",
        "https://*.airbnb.com/*",
        "https://*.hyatt.com/*",
        "https://*.marriott.com/*",
        "https://*.hilton.com/*",
        "https://*.wholefoodsmarket.com/*",
        "https://*.uber.com/*",
        "https://*.ubereats.com/*",
        "https://*.chipotle.com/*",
        "https://*.sephora.com/*",
        "https://card-reader-xi.vercel.app/*",
        "http://localhost:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Card Reader",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
